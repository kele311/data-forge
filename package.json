{
  "name": "data-forge",
  "version": "1.0.0",
  "description": "Lightning-fast CSV ↔ JSON converter and validator with streaming support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "data-forge": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "csv",
    "json",
    "converter",
    "validator",
    "data",
    "transform",
    "streaming"
  ],
  "author": "kele311",
  "license": "MIT",
  "dependencies": {
    "csv-parse": "^5.4.1",
    "csv-stringify": "^6.4.0",
    "yargs": "^17.7.2",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kele311/data-forge.git"
  },
  "bugs": {
    "url": "https://github.com/kele311/data-forge/issues"
  },
  "homepage": "https://github.com/kele311/data-forge#readme"
}
